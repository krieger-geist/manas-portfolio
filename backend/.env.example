# Get this from https://resend.com after signing up (free tier: 3000 emails/month)
# Dashboard -> API Keys -> Create API Key
RESEND_API_KEY=re_your_api_key_here

# Sandbox sender that works immediately with no domain setup.
# Once you verify your own domain on Resend, you can change this to
# something like "Manas Suryavanshi <contact@yourdomain.com>"
RESEND_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>

# Where contact messages should land
CONTACT_TO_EMAIL=manas240surya@gmail.com

# Comma-separated list of frontend origins allowed to call this API
# e.g. https://yourusername.github.io,https://your-site.netlify.app
ALLOWED_ORIGINS=http://localhost:5500

# Set automatically by most hosts (Render/Railway) - safe to leave unset locally
PORT=8080
